nextflow_workflow {

    name "Test Workflow DIFFERENTIAL_EXPRESSION"
    script "subworkflows/local/differential_expression/main.nf"
    workflow "DIFFERENTIAL_EXPRESSION"

    tag "subworkflows"
    tag "subworkflows_local"

    test("Should run differential expression with leiden clustering") {

        when {
            params {
                outdir = "$outputDir"
            }
            workflow {
                """
                input[0] = channel.of([
                    [id: 'test'],
                    file(params.pipelines_testdata_base_path + '/pbmc/with_label_and_condition_pca.h5ad', checkIfExists: true)
                ]).map { meta, h5ad -> [meta + [obs_key: 'leiden', condition_col: 'condition'], h5ad] }
                """
            }
        }

        then {
            assertAll(
            { assert workflow.success },
            { assert snapshot(workflow.out.versions).match() },
            { assert workflow.out.uns.size() > 0 },
            { assert workflow.out.multiqc_files.size() > 0 }
            )
        }

    }

    test("Should run differential expression with label column") {

        when {
            params {
                outdir = "$outputDir"
            }
            workflow {
                """
                input[0] = channel.of([
                    [id: 'test'],
                    file(params.pipelines_testdata_base_path + '/pbmc/with_label_and_condition_pca.h5ad', checkIfExists: true)
                ]).map { meta, h5ad -> [meta + [obs_key: 'label', condition_col: 'condition'], h5ad] }
                """
            }
        }

        then {
            assertAll(
            { assert workflow.success },
            { assert snapshot(workflow.out.versions).match() },
            { assert workflow.out.uns.size() > 0 },
            { assert workflow.out.multiqc_files.size() > 0 }
            )
        }

    }

}
