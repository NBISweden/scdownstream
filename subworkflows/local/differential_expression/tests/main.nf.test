nextflow_workflow {

    name "Test Workflow DIFFERENTIAL_EXPRESSION"
    script "subworkflows/local/differential_expression/main.nf"
    workflow "DIFFERENTIAL_EXPRESSION"

    tag "subworkflows"
    tag "subworkflows_local"

    setup {
        run("ADATA_UNIFY") {
            script "modules/local/adata/unify/main.nf"
            process {
                """
                input[0] = channel.of([
                    [id: 'test'],
                    file(params.pipelines_testdata_base_path + '/anndata-variations/with_label_and_condition.h5ad', checkIfExists: true)
                ])
                input[1] = "sample"
                input[2] = "label"
                input[3] = "condition"
                input[4] = "unknown"
                input[5] = "index"
                input[6] = "X"
                input[7] = "sum"
                input[8] = false
                """
            }
        }
        run("SCANPY_PCA") {
            script "modules/local/scanpy/pca/main.nf"
            process {
                """
                input[0] = ADATA_UNIFY.out.h5ad
                input[1] = "X_pca"
                """
            }
        }
        run("SCANPY_NEIGHBORS") {
            script "modules/local/scanpy/neighbors/main.nf"
            process {
                """
                input[0] = SCANPY_PCA.out.h5ad
                input[1] = "X_pca"
                """
            }
        }
        run("SCANPY_LEIDEN") {
            script "modules/local/scanpy/leiden/main.nf"
            process {
                """
                input[0] = SCANPY_NEIGHBORS.out.h5ad
                input[1] = 1.0
                input[2] = "leiden"
                input[3] = false
                """
            }
        }
    }

    test("Should run differential expression with leiden clustering") {

        when {
            params {
                outdir = "$outputDir"
            }
            workflow {
                """
                input[0] = SCANPY_LEIDEN.out.h5ad.map { meta, h5ad -> [meta + [obs_key: 'leiden', condition_col: 'condition'], h5ad] }
                """
            }
        }

        then {
            assert workflow.success
            assert snapshot(workflow.out).match()
        }

    }

    test("Should run differential expression with label column") {

        when {
            params {
                outdir = "$outputDir"
            }
            workflow {
                """
                input[0] = SCANPY_LEIDEN.out.h5ad.map { meta, h5ad -> [meta + [obs_key: 'label', condition_col: 'condition'], h5ad] }
                """
            }
        }

        then {
            assert workflow.success
            assert snapshot(workflow.out).match()
        }

    }

}
