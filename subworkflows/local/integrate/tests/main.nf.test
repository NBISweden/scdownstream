nextflow_workflow {

    name "Test Workflow INTEGRATE"
    script "subworkflows/local/integrate/main.nf"
    workflow "INTEGRATE"

    tag "subworkflows"
    tag "subworkflows_local"

    test("Should run without failures - harmony - stub") {

        options '-stub'

        when {
            params {
                outdir = "$outputDir"
            }
            workflow {
                """
                input[0] = channel.of([
                    [id: 'test'],
                    file(params.pipelines_testdata_base_path + '/anndata-variations/batch_correct_name.h5ad', checkIfExists: true)
                ])
                input[1] = false
                input[2] = 2000
                input[3] = []
                input[4] = ['harmony']
                input[5] = null
                input[6] = null
                input[7] = []
                input[8] = []
                input[9] = null
                """
            }
        }

        then {
            assert workflow.success
            assert snapshot(workflow.out).match()
        }

    }

    test("Should run without failures - harmony") {

        when {
            params {
                outdir = "$outputDir"
            }
            workflow {
                """
                input[0] = channel.of([
                    [id: 'test'],
                    file(params.pipelines_testdata_base_path + '/anndata-variations/batch_correct_name.h5ad', checkIfExists: true)
                ])
                input[1] = false
                input[2] = 2000
                input[3] = []
                input[4] = ['harmony']
                input[5] = null
                input[6] = null
                input[7] = []
                input[8] = []
                input[9] = null
                """
            }
        }

        then {
            def h5ad = workflow.out.integrations[0][1]
            assertAll(
            { assert workflow.success },
            { assert snapshot(workflow.out.versions, anndata(h5ad).yaml).match() },
            { assert "X_emb" in anndata(h5ad).obsm }
            )
        }

    }

