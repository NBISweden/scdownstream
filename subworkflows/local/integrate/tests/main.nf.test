    test("Should run without failures - bbknn") {

        when {
            params {
                outdir = "$outputDir"
            }
            workflow {
                """
                input[0] = channel.of([
                    [id: 'test'],
                    file(params.pipelines_testdata_base_path + '/anndata-variations/batch_correct_name.h5ad', checkIfExists: true)
                ])
                input[1] = false
                input[2] = 2000
                input[3] = []
                input[4] = ['bbknn']
                input[5] = null
