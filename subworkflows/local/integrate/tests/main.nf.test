        then {
            def h5ad = workflow.out.integrations[0][1]
            assertAll(
            { assert workflow.success },
            { assert snapshot(workflow.out.versions, anndata(h5ad).yaml).match() },
            { assert "connectivities" in anndata(h5ad).obsp },
            { assert "distances" in anndata(h5ad).obsp }
            )
        }

    }

