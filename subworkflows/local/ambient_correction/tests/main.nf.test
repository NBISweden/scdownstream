nextflow_workflow {

    name "Test Workflow AMBIENT_CORRECTION"
    script "subworkflows/local/ambient_correction/main.nf"
    workflow "AMBIENT_CORRECTION"

    tag "subworkflows"
    tag "subworkflows_local"

    test("Should run with 'none' ambient correction") {

        when {
            params {
                outdir = "$outputDir"
            }
            workflow {
                """
                input[0] = channel.of([
                        [ id: 'test' ],
                        file(params.modules_testdata_base_path + 'genomics/homo_sapiens/scrnaseq/h5ad/SRR28679759_filtered_matrix.h5ad', checkIfExists: true),
                        file(params.modules_testdata_base_path + 'genomics/homo_sapiens/scrnaseq/h5ad/SRR28679759_raw_matrix.h5ad', checkIfExists: true)
                    ]
                )
                input[1] = 'none'
                input[2] = false
                """
            }
        }

        then {
            assertAll(
            { assert workflow.success },
            { assert snapshot(workflow.out.versions).match() }
            )
        }

    }

    test("Should fail with unknown ambient correction method") {

        when {
            params {
                outdir = "$outputDir"
            }
            workflow {
                """
                input[0] = channel.of([
                        [ id: 'test' ],
                        file(params.modules_testdata_base_path + 'genomics/homo_sapiens/scrnaseq/h5ad/SRR28679759_filtered_matrix.h5ad', checkIfExists: true),
                        file(params.modules_testdata_base_path + 'genomics/homo_sapiens/scrnaseq/h5ad/SRR28679759_raw_matrix.h5ad', checkIfExists: true)
                    ]
                )
                input[1] = 'test'
                input[2] = false
                """
            }
        }

        then {
            assert !workflow.success
        }

    }

    test("Should not do anything if ambient correction is disabled in meta") {

        when {
            params {
                outdir = "$outputDir"
            }
            workflow {
                """
                input[0] = channel.of([
                        [ id: 'test', batch_col: 'sample', counts_layer: 'X', ambient_correction: false ],
                        file(params.modules_testdata_base_path + 'genomics/homo_sapiens/scrnaseq/h5ad/SRR28679759_filtered_matrix.h5ad', checkIfExists: true),
                        file(params.modules_testdata_base_path + 'genomics/homo_sapiens/scrnaseq/h5ad/SRR28679759_raw_matrix.h5ad', checkIfExists: true)
                    ]
                )
                input[1] = 'decontx'
                input[2] = false
                """
            }
        }

        then {
            assertAll(
            { assert workflow.success },
            { assert snapshot(workflow.out.versions).match() }
            )
        }

    }

    test("Should run with 'decontx' ambient correction") {

        when {
            params {
                outdir = "$outputDir"
            }
            workflow {
                """
                input[0] = channel.of([
                        [ id: 'test', batch_col: 'sample', counts_layer: 'X' ],
                        file(params.modules_testdata_base_path + 'genomics/homo_sapiens/scrnaseq/h5ad/SRR28679759_filtered_matrix.h5ad', checkIfExists: true),
                        file(params.modules_testdata_base_path + 'genomics/homo_sapiens/scrnaseq/h5ad/SRR28679759_raw_matrix.h5ad', checkIfExists: true)
                    ]
                )
                input[1] = 'decontx'
                input[2] = false
                """
            }
        }

        then {
            def h5ad = workflow.out.h5ad[0][1]
            assertAll(
            { assert workflow.success },
            { assert snapshot(workflow.out.versions).match() },
            { assert "ambient_corrected_decontx" in anndata(h5ad).layers }
            )
        }

    }

