nextflow_workflow {

    name "Test Workflow PER_GROUP"
    script "subworkflows/local/per_group/main.nf"
    workflow "PER_GROUP"

    tag "subworkflows"
    tag "subworkflows_local"

    setup {
        run("SCANPY_PCA") {
            script "modules/local/scanpy/pca/main.nf"
            process {
                """
                input[0] = channel.of([
                    [id: 'test'],
                    file(params.pipelines_testdata_base_path + '/extension_base/merged.h5ad', checkIfExists: true)
                ])
                input[1] = "X_pca"
                """
            }
        }
        run("SCANPY_NEIGHBORS") {
            script "modules/local/scanpy/neighbors/main.nf"
            process {
                """
                input[0] = SCANPY_PCA.out.h5ad
                input[1] = "X_pca"
                """
            }
        }
        run("SCANPY_LEIDEN") {
            script "modules/local/scanpy/leiden/main.nf"
            process {
                """
                input[0] = SCANPY_NEIGHBORS.out.h5ad
                input[1] = 1.0
                input[2] = "leiden"
                input[3] = false
                """
            }
        }
    }

    test("Should run without failures - PAGA only - stub") {

        options '-stub'

        when {
            params {
                outdir = "$outputDir"
                skip_liana = true
                skip_rankgenesgroups = true
            }
            workflow {
                """
                input[0] = SCANPY_LEIDEN.out.h5ad.map { meta, h5ad -> [meta + [integration: 'pca'], h5ad] }
                input[1] = channel.empty()
                input[2] = channel.empty()
                """
            }
        }

        then {
            assert workflow.success
            assert snapshot(workflow.out).match()
        }

    }

    test("Should run without failures - PAGA only") {

        when {
            params {
                outdir = "$outputDir"
                skip_liana = true
                skip_rankgenesgroups = true
            }
            workflow {
                """
                input[0] = SCANPY_LEIDEN.out.h5ad.map { meta, h5ad -> [meta + [integration: 'pca'], h5ad] }
                input[1] = channel.empty()
                input[2] = channel.empty()
                """
            }
        }

        then {
            assert workflow.success
            assert snapshot(workflow.out).match()
        }

    }

    test("Should run without failures - full run - stub") {

        options '-stub'

        when {
            params {
                outdir = "$outputDir"
                skip_liana = false
                skip_rankgenesgroups = false
            }
            workflow {
                """
                input[0] = SCANPY_LEIDEN.out.h5ad.map { meta, h5ad -> [meta + [integration: 'pca'], h5ad] }
                input[1] = channel.empty()
                input[2] = SCANPY_LEIDEN.out.h5ad
                """
            }
        }

        then {
            assert workflow.success
            assert snapshot(workflow.out).match()
        }

    }

    test("Should run without failures - full run") {

        when {
            params {
                outdir = "$outputDir"
                skip_liana = false
                skip_rankgenesgroups = false
            }
            workflow {
                """
                input[0] = SCANPY_LEIDEN.out.h5ad.map { meta, h5ad -> [meta + [integration: 'pca'], h5ad] }
                input[1] = channel.empty()
                input[2] = SCANPY_LEIDEN.out.h5ad
                """
            }
        }

        then {
            assert workflow.success
            assert snapshot(workflow.out).match()
        }

    }

}
