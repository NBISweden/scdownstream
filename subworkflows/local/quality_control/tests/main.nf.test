nextflow_workflow {

    name "Test Workflow QUALITY_CONTROL"
    script "subworkflows/local/quality_control/main.nf"
    workflow "QUALITY_CONTROL"

    tag "subworkflows"
    tag "subworkflows_local"

    test("Should run without ambient RNA removal and doublet detection") {

        when {
            params {
                outdir = "$outputDir"
            }
            workflow {
                """
                input[0] = channel.of([
                        [ id: 'test', batch_col: 'sample', counts_layer: 'X' ],
                        file(params.modules_testdata_base_path + 'genomics/homo_sapiens/scrnaseq/h5ad/SRR28679756_filtered_matrix.h5ad', checkIfExists: true),
                        file(params.modules_testdata_base_path + 'genomics/homo_sapiens/scrnaseq/h5ad/SRR28679756_raw_matrix.h5ad', checkIfExists: true)
                    ]
                )
                input[1] = 'none'
                input[2] = false
                input[3] = false
                input[4] = 'sum'
                input[5] = false
                input[6] = 'none'
                input[7] = 1
                input[8] = null
                input[9] = null
                input[10] = null
                input[11] = null
                input[12] = false
                input[13] = []
                input[14] = []
                """
            }
        }

        then {
            assert workflow.success
            // sample is fully filtered out by SCANPY_FILTER quality thresholds
            assert workflow.out.h5ad.size() == 0
            assert snapshot(
                workflow.out.multiqc_files,
                workflow.out.versions.collect { path(it).yaml }
            ).match()
        }

    }

    test("Should run without ambient RNA removal and doublet detection, but with custom mito genes") {

        when {
            params {
                outdir = "$outputDir"
            }
            workflow {
                """
                input[0] = channel.of([
                        [ id: 'test', batch_col: 'sample', counts_layer: 'X' ],
                        file(params.modules_testdata_base_path + 'genomics/homo_sapiens/scrnaseq/h5ad/SRR28679756_filtered_matrix.h5ad', checkIfExists: true),
                        file(params.modules_testdata_base_path + 'genomics/homo_sapiens/scrnaseq/h5ad/SRR28679756_raw_matrix.h5ad', checkIfExists: true)
                    ]
                )
                input[1] = 'none'
                input[2] = false
                input[3] = false
                input[4] = 'sum'
                input[5] = false
                input[6] = 'none'
                input[7] = 1
                input[8] = null
                input[9] = channel.of('POMP', 'DLG2')
                    .collectFile(name: 'mito_genes.txt')
                input[10] = null
                input[11] = null
                input[12] = false
                input[13] = []
                input[14] = []
                """
            }
        }

        then {
            assert workflow.success
            // sample is fully filtered out by SCANPY_FILTER quality thresholds
            assert workflow.out.h5ad.size() == 0
            assert snapshot(
                workflow.out.multiqc_files,
                workflow.out.versions.collect { path(it).yaml }
            ).match()
        }

    }

    test("Should run with ambient RNA removal and doublet detection") {

        when {
            params {
                outdir = "$outputDir"
            }
            workflow {
                """
                input[0] = channel.of([
                        [ id: 'test', batch_col: 'sample', counts_layer: 'X' ],
                        file(params.modules_testdata_base_path + 'genomics/homo_sapiens/scrnaseq/h5ad/SRR28679756_filtered_matrix.h5ad', checkIfExists: true),
                        file(params.modules_testdata_base_path + 'genomics/homo_sapiens/scrnaseq/h5ad/SRR28679756_raw_matrix.h5ad', checkIfExists: true)
                    ]
                )
                input[1] = 'decontx'
                input[2] = false
                input[3] = false
                input[4] = 'sum'
                input[5] = false
                input[6] = ['scrublet']
                input[7] = 1
                input[8] = null
                input[9] = null
                input[10] = null
                input[11] = null
                input[12] = false
                input[13] = []
                input[14] = []
                """
            }
        }

        then {
            def adata = anndata(workflow.out.h5ad[0][1])

            assert workflow.success
            with(adata) {
                assert "pct_counts_mt" in obs.colnames
                assert "batch" in obs.colnames
                assert "label" in obs.colnames
                assert "condition" in obs.colnames
                assert "sample" in obs.colnames
            }
            assert snapshot(
                workflow.out.multiqc_files,
                workflow.out.versions.collect { path(it).yaml },
                adata.n_obs,
                adata.n_vars,
                adata.yaml
            ).match()
        }

    }

    test("Should run with ambient RNA removal and doublet detection - stub") {

        options '-stub'

        when {
            params {
                outdir = "$outputDir"
            }
            workflow {
                """
                input[0] = channel.of([
                        [ id: 'test', batch_col: 'sample', counts_layer: 'X' ],
                        file(params.modules_testdata_base_path + 'genomics/homo_sapiens/scrnaseq/h5ad/SRR28679756_filtered_matrix.h5ad', checkIfExists: true),
                        file(params.modules_testdata_base_path + 'genomics/homo_sapiens/scrnaseq/h5ad/SRR28679756_raw_matrix.h5ad', checkIfExists: true)
                    ]
                )
                input[1] = 'decontx'
                input[2] = false
                input[3] = false
                input[4] = 'sum'
                input[5] = false
                input[6] = ['scrublet']
                input[7] = 1
                input[8] = null
                input[9] = null
                input[10] = null
                input[11] = null
                input[12] = false
                input[13] = []
                input[14] = []
                """
            }
        }

        then {
            assert workflow.success
            assert snapshot(workflow.out).match()
        }

    }

    test("Should run with cell cycle scoring") {

        when {
            params {
                outdir = "$outputDir"
            }
            workflow {
                """
                input[0] = channel.of([
                        [ id: 'test', batch_col: 'sample', counts_layer: 'X' ],
                        file(params.modules_testdata_base_path + 'genomics/homo_sapiens/scrnaseq/h5ad/SRR28679756_filtered_matrix.h5ad', checkIfExists: true),
                        file(params.modules_testdata_base_path + 'genomics/homo_sapiens/scrnaseq/h5ad/SRR28679756_raw_matrix.h5ad', checkIfExists: true)
                    ]
                )
                input[1] = 'none'
                input[2] = false
                input[3] = false
                input[4] = 'sum'
                input[5] = false
                input[6] = 'none'
                input[7] = 1
                input[8] = null
                input[9] = null
                input[10] = null
                input[11] = null
                input[12] = true
                input[13] = file("${projectDir}/assets/cell_cycle_genes/human_s_genes.txt")
                input[14] = file("${projectDir}/assets/cell_cycle_genes/human_g2m_genes.txt")
                """
            }
        }

        then {
            assert workflow.success
            // sample is fully filtered out by SCANPY_FILTER quality thresholds
            assert workflow.out.h5ad.size() == 0
            assert snapshot(
                workflow.out.multiqc_files,
                workflow.out.versions.collect { path(it).yaml }
            ).match()
        }

    }

}
