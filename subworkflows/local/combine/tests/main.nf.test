nextflow_workflow {

    name "Test Workflow COMBINE"
    script "subworkflows/local/combine/main.nf"
    workflow "COMBINE"

    tag "subworkflows"
    tag "subworkflows_local"

    test("Should run without failures - without base - stub") {

        options '-stub'

        when {
            params {
                outdir = "$outputDir"
            }
            workflow {
                """
                input[0]  = channel.of(
                    [[id: 'test1'], file(params.pipelines_testdata_base_path + '/anndata-variations/batch_correct_name.h5ad', checkIfExists: true)],
                    [[id: 'test2'], file(params.pipelines_testdata_base_path + '/anndata-variations/batch_correct_name.h5ad', checkIfExists: true)]
                )
                input[1]  = channel.value([[], []])
                input[2]  = false
                input[3]  = 0
                input[4]  = 'scvi'
                input[5]  = null
                input[6]  = null
                input[7]  = null
                input[8]  = ''
                input[9]  = ''
                input[10] = 'https://zenodo.org/records/10685499/files/model_v1.1.tar.gz'
                """
            }
        }

        then {
            assert workflow.success
            assert snapshot(workflow.out).match()
        }

    }

    test("Should run without failures - without base") {

        when {
            params {
                outdir = "$outputDir"
            }
            workflow {
                """
                input[0] = channel.of(
                    [[id: 'test1'], file(params.pipelines_testdata_base_path + '/anndata-variations/batch_correct_name.h5ad', checkIfExists: true)],
                    [[id: 'test2'], file(params.pipelines_testdata_base_path + '/anndata-variations/batch_correct_name.h5ad', checkIfExists: true)]
                )
                input[1]  = channel.value([[], []])
                input[2]  = false
                input[3]  = 0
                input[4]  = 'scvi'
                input[5]  = null
                input[6]  = null
                input[7]  = null
                input[8]  = ''
                input[9]  = ''
                input[10] = 'https://zenodo.org/records/10685499/files/model_v1.1.tar.gz'
                """
            }
        }

        then {
            def adata = anndata(workflow.out.h5ad[0][1])
            assert workflow.success
            assert "batch" in adata.obs.colnames
            assert snapshot(
                workflow.out.h5ad,
                workflow.out.h5ad_inner,
                workflow.out.var,
                workflow.out.versions.collect { path(it).yaml },
                adata.yaml
            ).match()
        }

    }

}
