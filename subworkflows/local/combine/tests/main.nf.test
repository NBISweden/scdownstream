nextflow_workflow {

    name "Test Workflow COMBINE"
    script "subworkflows/local/combine/main.nf"
    workflow "COMBINE"

    tag "subworkflows"
    tag "subworkflows_local"

    test("Should run without failures - without base - stub") {

        options '-stub'

        when {
            params {
                outdir = "$outputDir"
                base_adata = null
                integration_hvgs = 2000
                integration_excluded_genes = null
                integration_methods = "harmony"
                scvi_model = null
                scanvi_model = null
                scvi_categorical_covariates = []
                scvi_continuous_covariates = []
                scimilarity_model = null
            }
            workflow {
                """
                input[0]  = channel.of(
                    [[id: 'test1'], file(params.pipelines_testdata_base_path + '/anndata-variations/batch_correct_name.h5ad', checkIfExists: true)],
                    [[id: 'test2'], file(params.pipelines_testdata_base_path + '/anndata-variations/batch_correct_name.h5ad', checkIfExists: true)]
                )
                input[1]  = channel.empty()
                input[2]  = null
                input[3]  = 0
                input[4]  = 'scvi'
                input[5]  = null
                input[6]  = null
                input[7]  = null
                input[8]  = ''
                input[9]  = ''
                input[10] = 'https://zenodo.org/records/10685499/files/model_v1.1.tar.gz'
                """
            }
        }

        then {
            assert workflow.success
            assert snapshot(workflow.out).match()
        }

    }

    test("Should run without failures - without base") {

        when {
            params {
                outdir = "$outputDir"
                base_adata = null
                integration_hvgs = 2000
                integration_excluded_genes = null
                integration_methods = "harmony"
                scvi_model = null
                scanvi_model = null
                scvi_categorical_covariates = []
                scvi_continuous_covariates = []
                scimilarity_model = null
            }
            workflow {
                """
                input[0] = channel.of(
                    [[id: 'test1'], file(params.pipelines_testdata_base_path + '/anndata-variations/batch_correct_name.h5ad', checkIfExists: true)],
                    [[id: 'test2'], file(params.pipelines_testdata_base_path + '/anndata-variations/batch_correct_name.h5ad', checkIfExists: true)]
                )
                input[1]  = channel.empty()
                input[2]  = null
                input[3]  = 0
                input[4]  = 'scvi'
                input[5]  = null
                input[6]  = null
                input[7]  = null
                input[8]  = ''
                input[9]  = ''
                input[10] = 'https://zenodo.org/records/10685499/files/model_v1.1.tar.gz'
                """
            }
        }

        then {
            assert workflow.success
            assert snapshot(workflow.out).match()
        }

    }

}
