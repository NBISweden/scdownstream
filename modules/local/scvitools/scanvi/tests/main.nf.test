nextflow_process {

    name "Test Process SCVITOOLS_SCANVI"
    script "modules/local/scvitools/scanvi/main.nf"
    process "SCVITOOLS_SCANVI"

    tag "modules"
    tag "modules_local"

    setup {
        run("SCANPY_HVGS") {
            script "modules/local/scanpy/hvgs/main.nf"
            process {
                """
                input[0] = channel.of([
                        [ id: 'test' ],
                        file(params.pipelines_testdata_base_path + '/pbmc/with_label_and_condition_pca.h5ad', checkIfExists: true)
                    ]
                )
                input[1] = 100
                input[2] = []
                """
            }
        }
    }

    test("Should run without failures") {

        config './nextflow.config'

        when {
            params {
                outdir = "$outputDir"
            }
            process {
                """
                input[0] = SCANPY_HVGS.out.h5ad
                input[1] = [[], []]
                input[2] = ['label', 'Unknown']
                input[3] = 'sample'
                input[4] = ''
                input[5] = ''
                """
            }
        }

        then {
            def adata = anndata(process.out.h5ad[0][1])
            assert process.success
            with(adata) {
                assert "X_emb" in obsm
            }
            assert snapshot(
                    // Hashes are not stable due to floating point inaccuracies
                    file(process.out.h5ad[0][1]).name,
                    file(process.out.model[0][1]).name,
                    file(process.out.obsm[0]).name,
                    path(process.out.versions[0]).yaml,
                    adata.yaml
                ).match()
        }

    }

    test("Should run without failures - stub") {

        config './nextflow.config'
        options '-stub'

        when {
            params {
                outdir = "$outputDir"
            }
            process {
                """
                input[0] = SCANPY_HVGS.out.h5ad
                input[1] = [[], []]
                input[2] = ['label', 'Unknown']
                input[3] = 'sample'
                input[4] = ''
                input[5] = ''
                """
            }
        }

        then {
            assert process.success
            assert snapshot(process.out).match()
        }

    }

    test("Should write label predictions to obs") {

        config './nextflow.config'

        when {
            params {
                outdir = "$outputDir"
            }
            process {
                """
                input[0] = SCANPY_HVGS.out.h5ad
                input[1] = [[], []]
                input[2] = ['label', 'Unknown']
                input[3] = 'batch'
                input[4] = ''
                input[5] = ''
                """
            }
        }

        then {
            assertAll(
                { assert process.success },
                {
                    with(anndata(process.out.h5ad[0][1])) {
                        assert "label:scANVI" in obs.colnames
                        assert obs.get("label:scANVI").unique().size() > 1
                    }
                }
            )
        }

    }

}
