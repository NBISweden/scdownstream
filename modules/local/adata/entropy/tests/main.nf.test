nextflow_process {

    name "Test Process ADATA_ENTROPY"
    script "modules/local/adata/entropy/main.nf"
    process "ADATA_ENTROPY"
    tag "modules"
    tag "modules_local"

    test("Should run without failures") {

        config './nextflow.config'

        when {
            params {
                outdir = "$outputDir"
            }
            process {
                """
                input[0] = channel.of([
                        [ id: 'test' ],
                        file(params.pipelines_testdata_base_path + '/pbmc/combined_filtered_pca.h5ad', checkIfExists: true)
                    ]
                )
                input[1] = 'leiden'
                input[2] = 'sample'
                """
            }
        }

        then {
            def adata = anndata(process.out.h5ad[0][1])
            assert process.success
            assert snapshot(
                process.out,
                path(process.out.versions[0]).yaml,
                adata.yaml
            ).match()
        }

    }

    test("Should run without failures - stub") {

        options '-stub'

        when {
            params {
                outdir = "$outputDir"
            }
            process {
                """
                input[0] = channel.of([
                        [ id: 'test' ],
                        file(params.pipelines_testdata_base_path + '/pbmc/combined_filtered_pca.h5ad', checkIfExists: true)
                    ]
                )
                input[1] = 'leiden'
                input[2] = 'sample'
                """
            }
        }

        then {
            assert process.success

            assert snapshot(process.out).match()
        }

    }

}
