nextflow_process {

    name "Test Process ADATA_EXTEND"
    script "modules/local/adata/extend/main.nf"
    process "ADATA_EXTEND"

    tag "modules"
    tag "modules_local"

    test("Should extend with obs data") {

        when {
            params {
                outdir = "$outputDir"
            }
            process {
                """
                input[0] = channel.of([
                        [id: 'test'],
                        file(params.pipelines_testdata_base_path + '/intermediates/fragments/merged_outer.h5ad', checkIfExists: true),
                        [file(params.pipelines_testdata_base_path + '/intermediates/fragments/scvi-global-1.0_leiden.pkl', checkIfExists: true)],
                        [],
                        [],
                        [],
                        [],
                        []
                    ]
                )
                """
            }
        }

        then {
            def filename = process.out.h5ad[0][1]
            assertAll(
                { assert process.success },
                { assert snapshot(process.out).match() },
                {
                    with(anndata(filename)) {
                        assert "scvi-global-1.0_leiden" in obs.colnames
                    }
                }
            )
        }

    }

    test("Should extend with obsm data") {

        when {
            params {
                outdir = "$outputDir"
            }
            process {
                """
                input[0] = channel.of([
                        [id: 'test'],
                        file(params.pipelines_testdata_base_path + '/intermediates/fragments/merged_outer.h5ad', checkIfExists: true),
                        [],
                        [],
                        [file(params.pipelines_testdata_base_path + '/intermediates/fragments/X_scvi.pkl', checkIfExists: true)],
                        [],
                        [],
                        []
                    ]
                )
                """
            }
        }

        then {
            def filename = process.out.h5ad[0][1]
            assertAll(
                { assert process.success },
                { assert snapshot(process.out).match() },
                {
                    with(anndata(filename)) {
                        assert "X_scvi" in obsm
                    }
                }
            )
        }

    }

    test("Should extend with multiple obs and obsm data") {

        when {
            params {
                outdir = "$outputDir"
            }
            process {
                """
                input[0] = channel.of([
                        [id: 'test'],
                        file(params.pipelines_testdata_base_path + '/intermediates/fragments/merged_outer.h5ad', checkIfExists: true),
                        [
                            file(params.pipelines_testdata_base_path + '/intermediates/fragments/scvi-global-1.0_leiden.pkl', checkIfExists: true),
                            file(params.pipelines_testdata_base_path + '/intermediates/fragments/scvi-global-1.0_entropy.pkl', checkIfExists: true)
                        ],
                        [],
                        [
                            file(params.pipelines_testdata_base_path + '/intermediates/fragments/X_scvi.pkl', checkIfExists: true),
                            file(params.pipelines_testdata_base_path + '/intermediates/fragments/X_scvi-global_umap.pkl', checkIfExists: true)
                        ],
                        [],
                        [],
                        []
                    ]
                )
                """
            }
        }

        then {
            def filename = process.out.h5ad[0][1]
            assertAll(
                { assert process.success },
                { assert snapshot(process.out).match() },
                {
                    with(anndata(filename)) {
                        assert "scvi-global-1.0_leiden" in obs.colnames
                        assert "scvi-global-1.0:entropy" in obs.colnames
                        assert "X_scvi" in obsm
                        assert "X_scvi-global_umap" in obsm
                    }
                }
            )
        }

    }

    test("Should extend with uns data") {

        when {
            params {
                outdir = "$outputDir"
            }
            process {
                """
                input[0] = channel.of([
                        [id: 'test'],
                        file(params.pipelines_testdata_base_path + '/intermediates/fragments/merged_outer.h5ad', checkIfExists: true),
                        [],
                        [],
                        [],
                        [],
                        [file(params.pipelines_testdata_base_path + '/intermediates/fragments/scvi-global-1.0_paga.pkl', checkIfExists: true)],
                        []
                    ]
                )
                """
            }
        }

        then {
            def filename = process.out.h5ad[0][1]
            assertAll(
                { assert process.success },
                { assert snapshot(process.out).match() },
                {
                    with(anndata(filename)) {
                        assert "scvi-global-1.0_paga" in uns
                    }
                }
            )
        }

    }

    test("Should run with no extensions") {

        when {
            params {
                outdir = "$outputDir"
            }
            process {
                """
                input[0] = channel.of([
                        [id: 'test'],
                        file(params.pipelines_testdata_base_path + '/intermediates/fragments/merged_outer.h5ad', checkIfExists: true),
                        [],
                        [],
                        [],
                        [],
                        [],
                        []
                    ]
                )
                """
            }
        }

        then {
            assertAll(
                { assert process.success },
                { assert snapshot(process.out).match() }
            )
        }

    }

    test("Should run without failures - stub") {

        options '-stub'

        when {
            params {
                outdir = "$outputDir"
            }
            process {
                """
                input[0] = channel.of([
                        [id: 'test'],
                        file(params.pipelines_testdata_base_path + '/intermediates/fragments/merged_outer.h5ad', checkIfExists: true),
                        [],
                        [],
                        [],
                        [],
                        [],
                        []
                    ]
                )
                """
            }
        }

        then {
            assertAll(
                { assert process.success },
                { assert snapshot(process.out).match() }
            )
        }

    }

}
