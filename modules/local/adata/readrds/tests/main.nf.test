nextflow_process {

    name "Test Process ADATA_READRDS"
    script "modules/local/adata/readrds/main.nf"
    process "ADATA_READRDS"

    tag "modules"
    tag "modules_local"

    test("Should read seurat file") {

        when {
            params {
                outdir = "$outputDir"
            }
            process {
                """
                input[0] = channel.of([
                        [id: 'test'],
                        file(params.modules_testdata_base_path + 'genomics/homo_sapiens/scrnaseq/rds/SRR28679758_filtered_matrix.seurat.rds', checkIfExists: true)
                    ]
                )
                """
            }
        }

        then {
            def adata = anndata(process.out.h5ad[0][1])
            assert process.success
            assert snapshot(
                process.out,
                path(process.out.versions[0]).yaml,
                adata.yaml
            ).match()
        }

    }

    test("Should read seurat file - stub") {

        options '-stub'

        when {
            params {
                outdir = "$outputDir"
            }
            process {
                """
                input[0] = channel.of([
                        [id: 'test'],
                        file(params.modules_testdata_base_path + 'genomics/homo_sapiens/scrnaseq/rds/SRR28679758_filtered_matrix.seurat.rds', checkIfExists: true)
                    ]
                )
                """
            }
        }

        then {
            assert process.success

            assert snapshot(process.out).match()
        }

    }

    test("Should read SCE file") {

        when {
