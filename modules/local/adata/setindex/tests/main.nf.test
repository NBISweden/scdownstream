nextflow_process {

    name "Test Process ADATA_SETINDEX"
    script "modules/local/adata/setindex/main.nf"
    process "ADATA_SETINDEX"

    tag "modules"
    tag "modules_local"

    test("Should run without failures - obs") {

        when {
            params {
                outdir = "$outputDir"
            }
            process {
                """
                input[0] = channel.of([
                        [ id: 'test' ],
                        file(params.modules_testdata_base_path + 'genomics/homo_sapiens/scrnaseq/h5ad/SRR28679756_filtered_matrix.h5ad', checkIfExists: true)
                    ]
                )
                input[1] = "obs"
                input[2] = "sample"
                """
            }
        }

        then {
            assert process.success

            assert snapshot(process.out).match()
        }

    }

    test("Should run without failures - var") {

        when {
            params {
                outdir = "$outputDir"
            }
            process {
                """
                input[0] = channel.of([
                        [ id: 'test' ],
                        file(params.modules_testdata_base_path + 'genomics/homo_sapiens/scrnaseq/h5ad/SRR28679756_filtered_matrix.h5ad', checkIfExists: true)
                    ]
                )
                input[1] = "var"
                input[2] = "symbols"
                """
            }
        }

        then {
            assert process.success

            assert snapshot(process.out).match()
        }

    }

    test("Should run without failures - stub") {

        options '-stub'

        when {
            params {
                outdir = "$outputDir"
            }
            process {
                """
                input[0] = channel.of([
                        [ id: 'test' ],
                        file(params.modules_testdata_base_path + 'genomics/homo_sapiens/scrnaseq/h5ad/SRR28679756_filtered_matrix.h5ad', checkIfExists: true)
                    ]
                )
                input[1] = "obs"
                input[2] = "sample"
                """
            }
        }

        then {
            assert process.success

            assert snapshot(process.out).match()
        }

    }

    test("Should fail on invalid axis") {

        when {
            params {
                outdir = "$outputDir"
            }
            process {
                """
                input[0] = channel.of([
                        [ id: 'test' ],
                        file(params.modules_testdata_base_path + 'genomics/homo_sapiens/scrnaseq/h5ad/SRR28679756_filtered_matrix.h5ad', checkIfExists: true)
                    ]
                )
                input[1] = "invalid"
                input[2] = "sample"
                """
            }
        }

        then {
            assert process.failed
            assert process.errorReport.contains("Axis must be either 'obs' or 'var'")
        }

    }

    test("Should fail on non-existing column") {

        when {
            params {
                outdir = "$outputDir"
            }
            process {
                """
                input[0] = channel.of([
                        [ id: 'test' ],
                        file(params.modules_testdata_base_path + 'genomics/homo_sapiens/scrnaseq/h5ad/SRR28679756_filtered_matrix.h5ad', checkIfExists: true)
                    ]
                )
                input[1] = "obs"
                input[2] = "nonexistent_column"
                """
            }
        }

        then {
            assert process.failed
            assert process.errorReport.contains("Column 'nonexistent_column' not found in obs")
        }

    }

}
