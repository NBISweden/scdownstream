                input[6] = "X"
                input[7] = "sum"
                input[8] = false
                """
            }
        }

        then {
            assertAll(
                { assert process.success },
                { assert snapshot(process.out).match() }
            )
        }
    }

    // ============================================================================
    // 8. OBSERVATION METADATA VARIATIONS
    // ============================================================================

    test("Should handle duplicate cell names") {
        when {
            params {
                outdir = "$outputDir"
            }
            process {
                """
                input[0] = channel.of([
                        [id: 'test'],
                        file(params.pipelines_testdata_base_path + '/anndata-variations/obs_duplicate_names.h5ad', checkIfExists: true)
                    ]
                )
                input[1] = "sample"
                input[2] = ""
                input[3] = ""
                input[4] = "unknown"
                input[5] = "index"
                input[6] = "X"
                input[7] = "sum"
                input[8] = false
                """
            }
        }

        then {
            def filename = process.out.h5ad[0][1]
            assertAll(
                { assert process.success },
                { assert snapshot(process.out).match() },
                {
                    with(anndata(filename)) {
                        // All cell names should be prefixed
                        assert obs.rownames.every { it.startsWith("test_") }
                    }
                }
            )
        }
    }

    test("Should handle sample column with different value") {
        when {
            params {
                outdir = "$outputDir"
            }
            process {
                """
                input[0] = channel.of([
