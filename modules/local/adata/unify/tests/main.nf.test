    test("Should create batch column when missing") {
        when {
            params {
                outdir = "$outputDir"
            }
            process {
                """
                input[0] = channel.of([
                        [id: 'test'],
                        file(params.pipelines_testdata_base_path + '/anndata-variations/batch_missing.h5ad', checkIfExists: true)
