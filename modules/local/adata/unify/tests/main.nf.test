            assertAll(
                { assert process.success },
                { assert snapshot(process.out).match() },
                {
                    with(anndata(filename)) {
                        assert "batch" in obs.colnames
                        assert obs.get("batch").unique.every { it == "test_test" }
                    }
                }
            )
        }
    }

    test("Should fail on batch column conflict") {
        when {
            params {
                outdir = "$outputDir"
            }
            process {
                """
                input[0] = channel.of([
                        [id: 'test'],
                        file(params.pipelines_testdata_base_path + '/anndata-variations/batch_conflict.h5ad', checkIfExists: true)
                    ]
                )
                input[1] = "sample"
                input[2] = ""
                input[3] = ""
                input[4] = "unknown"
                input[5] = "index"
                input[6] = "X"
                input[7] = "sum"
                input[8] = false
                """
            }
        }

        then {
            assert process.failed
            assert process.errorReport.contains("The batch column already exists")
        }
    }

