                input[4] = "unknown"
                input[5] = "index"
                input[6] = "X"
                input[7] = "sum"
                input[8] = false
                """
            }
        }

        then {
            def filename = process.out.h5ad[0][1]
            assertAll(
                { assert process.success },
                { assert snapshot(process.out).match() },
                {
                    with(anndata(filename)) {
                        assert "sample" in obs.colnames
                        assert "sample_original" in obs.colnames
                        assert obs.get("sample").unique.every { it == "test" }
                    }
                }
            )
        }
    }

