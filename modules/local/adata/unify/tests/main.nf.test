    // ============================================================================
    // 4. ISOFORM AGGREGATION
    // ============================================================================

    test("Should aggregate isoforms") {
        when {
            params {
                outdir = "$outputDir"
            }
            process {
                """
                input[0] = channel.of([
                        [id: 'test'],
                        file(params.pipelines_testdata_base_path + '/anndata-variations/with_isoforms.h5ad', checkIfExists: true)
                    ]
                )
                input[1] = "sample"
                input[2] = ""
                input[3] = ""
                input[4] = "unknown"
                input[5] = "index"
                input[6] = "X"
                input[7] = "sum"
                input[8] = true
                """
            }
        }

        then {
            def filename = process.out.h5ad[0][1]
            assertAll(
                { assert process.success },
                { assert snapshot(process.out).match() },
                {
                    with(anndata(filename)) {
                        // After isoform aggregation, numeric suffixes should be removed
                        assert var.rownames.every { !it.matches(/.*\\.\\d+$/) }
                    }
                }
            )
        }
    }

    // ============================================================================
    // 5. BATCH COLUMN VARIATIONS
    // ============================================================================

    test("Should handle batch column with different name") {
        when {
            params {
                outdir = "$outputDir"
            }
            process {
                """
                input[0] = channel.of([
                        [id: 'test'],
                        file(params.pipelines_testdata_base_path + '/anndata-variations/batch_different_name.h5ad', checkIfExists: true)
                    ]
                )
                input[1] = "batch_id"
                input[2] = ""
                input[3] = ""
                input[4] = "unknown"
                input[5] = "index"
                input[6] = "X"
                input[7] = "sum"
                input[8] = false
                """
            }
        }

        then {
            def filename = process.out.h5ad[0][1]
            assertAll(
                { assert process.success },
                { assert snapshot(process.out).match() },
                {
                    with(anndata(filename)) {
                        assert "batch" in obs.colnames
                        assert !("batch_id" in obs.colnames)
                        assert obs.get("batch").unique.every { it.contains("_test") }
                    }
                }
            )
        }
    }

    test("Should handle batch column already named batch") {
        when {
            params {
                outdir = "$outputDir"
