nextflow_process {

    name "Test Process ADATA_UNIFY"
    script "modules/local/adata/unify/main.nf"
    process "ADATA_UNIFY"

    tag "modules"
    tag "modules_local"

    // ============================================================================
    // 1. COUNTS LAYER VARIATIONS
    // ============================================================================

    test("Should handle counts in X matrix") {
        when {
            params {
                outdir = "$outputDir"
            }
            process {
                """
                input[0] = channel.of([
                        [id: 'test'],
                        file(params.pipelines_testdata_base_path + '/anndata-variations/counts_in_X.h5ad', checkIfExists: true)
                    ]
                )
                input[1] = "sample"
                input[2] = ""
                input[3] = ""
                input[4] = "unknown"
                input[5] = "index"
                input[6] = "X"
                input[7] = "sum"
                input[8] = false
                """
            }
        }

        then {
            def filename = process.out.h5ad[0][1]
            assertAll(
                { assert process.success },
                { assert snapshot(process.out).match() },
                {
                    with(anndata(filename)) {
                        assert "batch" in obs.colnames
                        assert "label" in obs.colnames
                        assert "sample" in obs.colnames
                        assert !("counts" in layers)
                        assert layers.size() == 0
                    }
                }
            )
        }
    }

    test("Should handle counts in layer") {
        when {
            params {
                outdir = "$outputDir"
            }
            process {
                """
                input[0] = channel.of([
                        [id: 'test'],
                        file(params.pipelines_testdata_base_path + '/anndata-variations/counts_in_layer.h5ad', checkIfExists: true)
                    ]
                )
                input[1] = "sample"
                input[2] = ""
                input[3] = ""
                input[4] = "unknown"
                input[5] = "index"
                input[6] = "counts"
                input[7] = "sum"
                input[8] = false
                """
            }
        }

        then {
            def filename = process.out.h5ad[0][1]
            assertAll(
                { assert process.success },
                { assert snapshot(process.out).match() },
                {
                    with(anndata(filename)) {
                        assert "batch" in obs.colnames
                        assert "label" in obs.colnames
                        assert "sample" in obs.colnames
                        assert layers.size() == 0
                    }
                }
            )
        }
    }

