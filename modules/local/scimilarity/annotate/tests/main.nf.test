// NOTE: A full test is not feasible because the SCimilarity model
// file is almost 30GB large, which exceeds practical test data limits.
// Only stub tests are provided for this module.

nextflow_process {

    name "Test Process SCIMILARITY_ANNOTATE"
    script "modules/local/scimilarity/annotate/main.nf"
    process "SCIMILARITY_ANNOTATE"

    tag "modules"
    tag "modules_local"

    test("Should run without failures - stub") {

        options '-stub'

        when {
            params {
                outdir = "$outputDir"
            }
            process {
                """
                input[0] = channel.of([
                        [ id: 'test' ],
                        file(params.modules_testdata_base_path + 'genomics/homo_sapiens/scrnaseq/h5ad/SRR28679759_filtered_matrix.h5ad', checkIfExists: true)
                    ]
                )
                input[1] = channel.of([
                        [ id: 'model' ],
                        []
                    ]
                )
                """
            }
        }

        then {
            assertAll(
            { assert process.success },
            { assert snapshot(process.out).match() }
            )
        }

    }

}
