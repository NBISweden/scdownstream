nextflow_process {

    name "Test Process SCIMILARITY_PSEUDOBULK"
    script "modules/local/scimilarity/pseudobulk/main.nf"
    process "SCIMILARITY_PSEUDOBULK"

    tag "modules"
    tag "modules_local"

    test("Should run without failures with groupby batch") {

        config './nextflow.config'

        when {
            params {
                outdir = "$outputDir"
            }
            process {
                """
                input[0] = channel.of([
                        [ id: 'test' ],
                        file(params.modules_testdata_base_path + 'genomics/homo_sapiens/scrnaseq/h5ad/combined_filtered_matrix.h5ad', checkIfExists: true)
                    ]
                )
                input[1] = "X"
                input[2] = ["sample"]
                input[3] = 10
                """
            }
        }

        then {
            def adata = anndata(process.out.h5ad[0][1])
            assert process.success
            with(adata) {
                // one pseudobulk row per unique sample
                assert "sample" in obs.colnames
                assert n_obs > 0
            }
            assert snapshot(
                process.out,
                path(process.out.versions[0]).yaml,
                adata.yaml
            ).match()
        }

    }

    test("Should run without failures with groupby sample and clustering") {

        config './nextflow.config'

        when {
            params {
                outdir = "$outputDir"
            }
            process {
                """
                input[0] = channel.of([
                        [ id: 'test' ],
                        file(params.pipelines_testdata_base_path + '/pbmc/combined_filtered_pca.h5ad', checkIfExists: true)
                    ]
                )
                input[1] = "X"
                input[2] = ["sample", "leiden"]
                input[3] = 10
                """
            }
        }

        then {
            def adata = anndata(process.out.h5ad[0][1])
            assert process.success
            with(adata) {
                // one pseudobulk row per unique sample × leiden combination
                assert "sample" in obs.colnames
                assert "leiden" in obs.colnames
                assert n_obs > 0
            }
            assert snapshot(
                process.out,
                path(process.out.versions[0]).yaml,
                adata.yaml
            ).match()
        }

    }

    test("Should run without failures - stub") {

        config './nextflow.config'
        options '-stub'

        when {
            params {
                outdir = "$outputDir"
            }
            process {
                """
                input[0] = channel.of([
                        [ id: 'test' ],
                        file(params.modules_testdata_base_path + 'genomics/homo_sapiens/scrnaseq/h5ad/combined_filtered_matrix.h5ad', checkIfExists: true)
                    ]
                )
                input[1] = "X"
                input[2] = ["sample"]
                input[3] = 10
                """
            }
        }

        then {
            assert process.success
            assert snapshot(process.out).match()
        }

    }

}
