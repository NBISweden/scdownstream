nextflow_process {

    name "Test Process SCANPY_PCA"
    script "modules/local/scanpy/pca/main.nf"
    process "SCANPY_PCA"

    tag "modules"
    tag "modules_local"

    test("Should run without failures") {

        config './nextflow.config'

        when {
            params {
                outdir = "$outputDir"
            }
            process {
                """
                input[0] = channel.of([
                        [ id: 'test' ],
                        file(params.modules_testdata_base_path + 'genomics/homo_sapiens/scrnaseq/h5ad/combined_filtered_matrix.h5ad', checkIfExists: true)
                    ]
                )
                input[1] = "X_pca"
                """
            }
        }

        then {
            assertAll(
            { assert process.success },
            { assert snapshot(path(process.out.versions[0]).yaml, anndata(process.out.h5ad[0][1]).yaml).match() },
            { assert "X_pca" in anndata(process.out.h5ad[0][1]).obsm },
            { assert "X_pca" in anndata(process.out.h5ad[0][1]).uns }
            )
        }

    }

    test("Should run without failures - stub") {

        options '-stub'

        when {
            params {
                outdir = "$outputDir"
            }
            process {
                """
                input[0] = channel.of([
                        [ id: 'test' ],
                        file(params.modules_testdata_base_path + 'genomics/homo_sapiens/scrnaseq/h5ad/combined_filtered_matrix.h5ad', checkIfExists: true)
                    ]
                )
                input[1] = "X_pca"
                """
            }
        }

        then {
            assertAll(
            { assert process.success },
            { assert snapshot(process.out).match() }
            )
        }

    }

}
