nextflow_process {

    name "Test Process SCANPY_RANKGENESGROUPS"
    script "modules/local/scanpy/rankgenesgroups/main.nf"
    process "SCANPY_RANKGENESGROUPS"

    tag "modules"
    tag "modules_local"

    setup {
        run("ADATA_UNIFY", alias: "ADATA_UNIFY_SIMPLE") {
            script "modules/local/adata/unify/main.nf"
            process {
                """
                input[0] = channel.of([
                        [ id: 'test' ],
                        file(params.modules_testdata_base_path + 'genomics/homo_sapiens/scrnaseq/h5ad/SRR28679759_filtered_matrix.h5ad', checkIfExists: true)
                    ]
                )
                input[1] = "sample"
                input[2] = ""
                input[3] = ""
                input[4] = "unknown"
                input[5] = "index"
                input[6] = "X"
                input[7] = "sum"
                input[8] = false
                """
            }
        }
        run("ADATA_UNIFY", alias: "ADATA_UNIFY_WITH_CONDITION") {
            script "modules/local/adata/unify/main.nf"
            process {
                """
                input[0] = channel.of([
                        [ id: 'test' ],
                        file(params.pipelines_testdata_base_path + '/anndata-variations/with_label_and_condition.h5ad', checkIfExists: true)
                    ]
                )
                input[1] = "sample"
                input[2] = "label"
                input[3] = "condition"
                input[4] = "unknown"
                input[5] = "index"
                input[6] = "X"
                input[7] = "sum"
                input[8] = false
                """
            }
        }
        run("SCANPY_PCA", alias: "SCANPY_PCA_SIMPLE") {
            script "modules/local/scanpy/pca/main.nf"
            process {
                """
                input[0] = ADATA_UNIFY_SIMPLE.out.h5ad
                input[1] = "X_pca"
                """
            }
        }
        run("SCANPY_PCA", alias: "SCANPY_PCA_WITH_CONDITION") {
            script "modules/local/scanpy/pca/main.nf"
            process {
                """
                input[0] = ADATA_UNIFY_WITH_CONDITION.out.h5ad
                input[1] = "X_pca"
                """
            }
        }
        run("SCANPY_NEIGHBORS", alias: "SCANPY_NEIGHBORS_SIMPLE") {
            script "modules/local/scanpy/neighbors/main.nf"
            process {
                """
                input[0] = SCANPY_PCA_SIMPLE.out.h5ad
                input[1] = "X_pca"
                """
            }
        }
        run("SCANPY_NEIGHBORS", alias: "SCANPY_NEIGHBORS_WITH_CONDITION") {
            script "modules/local/scanpy/neighbors/main.nf"
            process {
                """
                input[0] = SCANPY_PCA_WITH_CONDITION.out.h5ad
                input[1] = "X_pca"
                """
            }
        }
        run("SCANPY_LEIDEN", alias: "SCANPY_LEIDEN_SIMPLE") {
            script "modules/local/scanpy/leiden/main.nf"
            process {
                """
                input[0] = SCANPY_NEIGHBORS_SIMPLE.out.h5ad
                input[1] = 1.0
                input[2] = "leiden"
                input[3] = false
                """
            }
        }
        run("SCANPY_LEIDEN", alias: "SCANPY_LEIDEN_WITH_CONDITION") {
            script "modules/local/scanpy/leiden/main.nf"
            process {
                """
                input[0] = SCANPY_NEIGHBORS_WITH_CONDITION.out.h5ad
                input[1] = 1.0
                input[2] = "leiden"
                input[3] = false
                """
            }
        }
    }

    test("Should run without failures") {

        when {
            params {
                outdir = "$outputDir"
            }
            process {
                """
                input[0] = SCANPY_LEIDEN_SIMPLE.out.h5ad
                input[1] = "leiden"
                input[2] = [[], []]
                input[3] = "wilcoxon"
                """
            }
        }

        then {
            assertAll(
            { assert process.success },
            { assert snapshot(process.out).match() }
            )
        }

    }

    test("Should run without failures - stub") {

        options '-stub'

        when {
            params {
                outdir = "$outputDir"
            }
            process {
                """
                input[0] = SCANPY_LEIDEN_SIMPLE.out.h5ad
                input[1] = "leiden"
                input[2] = [[], []]
                input[3] = "wilcoxon"
                """
            }
        }

        then {
            assertAll(
            { assert process.success },
            { assert snapshot(process.out).match() }
            )
        }

    }

    test("Should run with condition subsetting") {

        when {
            params {
                outdir = "$outputDir"
            }
            process {
                """
                input[0] = SCANPY_LEIDEN_WITH_CONDITION.out.h5ad
                input[1] = "leiden"
                input[2] = ["condition", "Healthy"]
                input[3] = "wilcoxon"
                """
            }
        }

        then {
            assertAll(
            { assert process.success },
            { assert snapshot(process.out).match() }
            )
        }

    }

    test("Should run with label subsetting") {

        when {
            params {
                outdir = "$outputDir"
            }
            process {
                """
                input[0] = SCANPY_LEIDEN_WITH_CONDITION.out.h5ad
                input[1] = "condition"
                input[2] = ["label", "Tcell"]
                input[3] = "wilcoxon"
                """
            }
        }

        then {
            assertAll(
            { assert process.success },
            { assert snapshot(process.out).match() }
            )
        }

    }

}
