nextflow_process {

    name "Test Process SCANPY_RANKGENESGROUPS"
    script "modules/local/scanpy/rankgenesgroups/main.nf"
    process "SCANPY_RANKGENESGROUPS"

    tag "modules"
    tag "modules_local"

    test("Should run without failures") {

        config './nextflow.config'

        when {
            params {
                outdir = "$outputDir"
            }
            process {
                """
                input[0] = channel.of([
                        [ id: 'test' ],
                        file(params.pipelines_testdata_base_path + '/pbmc/SRR28679759_filtered_pca.h5ad', checkIfExists: true)
                    ]
                )
                input[1] = "leiden"
                input[2] = [[], []]
                input[3] = "wilcoxon"
                """
            }
        }

        then {
            assertAll(
            { assert process.success },
            { assert snapshot(process.out.versions).match() },
            { assert process.out.uns.size() > 0 }
            )
        }

    }

    test("Should run without failures - stub") {

        options '-stub'

        when {
            params {
                outdir = "$outputDir"
            }
            process {
                """
                input[0] = channel.of([
                        [ id: 'test' ],
                        file(params.pipelines_testdata_base_path + '/pbmc/SRR28679759_filtered_pca.h5ad', checkIfExists: true)
                    ]
                )
                input[1] = "leiden"
                input[2] = [[], []]
                input[3] = "wilcoxon"
                """
            }
        }

        then {
            assertAll(
            { assert process.success },
            { assert snapshot(process.out).match() }
            )
        }

    }

    test("Should run with condition subsetting") {

        config './nextflow.config'

        when {
            params {
                outdir = "$outputDir"
            }
            process {
                """
                input[0] = channel.of([
                        [ id: 'test' ],
                        file(params.pipelines_testdata_base_path + '/pbmc/with_label_and_condition_pca.h5ad', checkIfExists: true)
                    ]
                )
                input[1] = "leiden"
                input[2] = ["condition", "Healthy"]
                input[3] = "wilcoxon"
                """
            }
        }

        then {
            assertAll(
            { assert process.success },
            { assert snapshot(process.out.versions).match() },
            { assert process.out.uns.size() > 0 }
            )
        }

    }

    test("Should run with label subsetting") {

        config './nextflow.config'

        when {
            params {
                outdir = "$outputDir"
            }
            process {
                """
                input[0] = channel.of([
                        [ id: 'test' ],
                        file(params.pipelines_testdata_base_path + '/pbmc/with_label_and_condition_pca.h5ad', checkIfExists: true)
                    ]
                )
                input[1] = "condition"
                input[2] = ["label", "Tcell"]
                input[3] = "wilcoxon"
                """
            }
        }

        then {
            assertAll(
            { assert process.success },
            { assert snapshot(process.out.versions).match() }
            )
        }

    }

}
