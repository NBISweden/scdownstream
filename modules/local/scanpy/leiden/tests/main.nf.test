nextflow_process {

    name "Test Process SCANPY_LEIDEN"
    script "modules/local/scanpy/leiden/main.nf"
    process "SCANPY_LEIDEN"

    tag "modules"
    tag "modules_local"

    test("Should run without failures") {

        config './nextflow.config'

        when {
            params {
                outdir = "$outputDir"
            }
            process {
                """
                input[0] = channel.of([
                        [ id: 'test' ],
                        file(params.pipelines_testdata_base_path + '/pbmc/SRR28679759_filtered_pca.h5ad', checkIfExists: true)
                    ]
                )
                input[1] = 1.0
                input[2] = "leiden"
                input[3] = false
                """
            }
        }

        then {
            assertAll(
            { assert process.success },
            { assert snapshot(process.out.versions).match() },
            {
                def obs = anndata(process.out.h5ad[0][1]).obs
                assert "leiden" in obs.colnames
                def n_clusters = obs.get("leiden").n_unique()
                assert n_clusters >= 5 && n_clusters <= 30 : "Expected 5–30 Leiden clusters, got ${n_clusters}"
            }
            )
        }

    }

    test("Should run without failures - stub") {

        options '-stub'

        when {
            params {
                outdir = "$outputDir"
            }
            process {
                """
                input[0] = channel.of([
                        [ id: 'test' ],
                        file(params.pipelines_testdata_base_path + '/pbmc/SRR28679759_filtered_pca.h5ad', checkIfExists: true)
                    ]
                )
                input[1] = 1.0
                input[2] = "leiden"
                input[3] = false
                """
            }
        }

        then {
            assertAll(
            { assert process.success },
            { assert snapshot(process.out).match() }
            )
        }

    }

}
