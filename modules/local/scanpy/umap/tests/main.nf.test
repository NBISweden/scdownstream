nextflow_process {

    name "Test Process SCANPY_UMAP"
    script "modules/local/scanpy/umap/main.nf"
    process "SCANPY_UMAP"

    tag "modules"
    tag "modules_local"

    test("Should run without failures") {

        config './nextflow.config'

        when {
            params {
                outdir = "$outputDir"
            }
            process {
                """
                input[0] = channel.of([
                        [ id: 'test' ],
                        file(params.pipelines_testdata_base_path + '/pbmc/SRR28679759_filtered_pca.h5ad', checkIfExists: true)
                    ]
                )
                """
            }
        }

        then {
            def adata = anndata(process.out.h5ad[0][1])

            assert process.success

            assert "X_umap" in adata.obsm

            assert snapshot(
                path(process.out.versions[0]).yaml,
                adata.yaml
            ).match()
        }

    }

    test("Should run without failures - stub") {

        options '-stub'

        when {
            params {
                outdir = "$outputDir"
            }
            process {
                """
                input[0] = channel.of([
                        [ id: 'test' ],
                        file(params.pipelines_testdata_base_path + '/pbmc/SRR28679759_filtered_pca.h5ad', checkIfExists: true)
                    ]
                )
                """
            }
        }

        then {
            assert process.success

            assert snapshot(process.out).match()
        }

    }

}
