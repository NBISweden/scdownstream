nextflow_process {

    name "Test Process CELDA_DECONTX"
    script "modules/local/celda/decontx/main.nf"
    process "CELDA_DECONTX"

    tag "modules"
    tag "modules_local"

    test("Should run without failures without batch column") {

        when {
            params {
                outdir = "$outputDir"
            }
            process {
                """
                input[0] = channel.of([
                        [ id: 'test' ],
                        file(params.modules_testdata_base_path + 'genomics/homo_sapiens/scrnaseq/h5ad/SRR28679756_filtered_matrix.h5ad', checkIfExists: true),
                        []
                    ]
                )
                input[1] = []
                input[2] = "X"
                input[3] = "X"
                """
            }
        }

        then {
            def h5ad = process.out.h5ad[0][1]
            assertAll(
            { assert process.success },
            { assert snapshot(path(process.out.versions[0]).yaml, anndata(h5ad).yaml).match() }
            )
        }

    }

    test("Should run without failures without raw - single batch") {

        when {
            params {
                outdir = "$outputDir"
            }
            process {
                """
                input[0] = channel.of([
                        [ id: 'test' ],
                        file(params.modules_testdata_base_path + 'genomics/homo_sapiens/scrnaseq/h5ad/SRR28679756_filtered_matrix.h5ad', checkIfExists: true),
                        []
                    ]
                )
                input[1] = "sample"
                input[2] = "X"
                input[3] = "X"
                """
            }
        }

        then {
            def h5ad = process.out.h5ad[0][1]
            assertAll(
            { assert process.success },
            { assert snapshot(path(process.out.versions[0]).yaml, anndata(h5ad).yaml).match() }
            )
        }

    }

    test("Should run without failures without raw - multi-batch") {

        when {
            params {
                outdir = "$outputDir"
            }
            process {
                """
                input[0] = channel.of([
                        [ id: 'test' ],
                        file(params.modules_testdata_base_path + 'genomics/homo_sapiens/scrnaseq/h5ad/combined_filtered_matrix.h5ad', checkIfExists: true),
                        []
                    ]
                )
                input[1] = "sample"
                input[2] = "X"
                input[3] = "X"
                """
            }
        }

        then {
            def h5ad = process.out.h5ad[0][1]
            assertAll(
            { assert process.success },
            { assert snapshot(path(process.out.versions[0]).yaml, anndata(h5ad).yaml).match() }
            )
        }

    }

    test("Should run without failures without raw - stub") {

        options '-stub'

        when {
            params {
                outdir = "$outputDir"
            }
            process {
                """
                input[0] = channel.of([
                        [ id: 'test' ],
                        file(params.modules_testdata_base_path + 'genomics/homo_sapiens/scrnaseq/h5ad/SRR28679756_filtered_matrix.h5ad', checkIfExists: true),
                        []
                    ]
                )
                input[1] = "sample"
                input[2] = "X"
                input[3] = "X"
                """
            }
        }

        then {
            assertAll(
            { assert process.success },
            { assert snapshot(process.out).match() }
            )
        }

    }

    test("Should run without failures with raw") {

        when {
            params {
                outdir = "$outputDir"
            }
            process {
                """
                input[0] = channel.of([
                        [ id: 'test' ],
                        file(params.modules_testdata_base_path + 'genomics/homo_sapiens/scrnaseq/h5ad/SRR28679756_filtered_matrix.h5ad', checkIfExists: true),
                        file(params.modules_testdata_base_path + 'genomics/homo_sapiens/scrnaseq/h5ad/SRR28679756_raw_matrix.h5ad', checkIfExists: true)
                    ]
                )
                input[1] = "sample"
                input[2] = "X"
                input[3] = "X"
                """
            }
        }

        then {
            def h5ad = process.out.h5ad[0][1]
            assertAll(
            { assert process.success },
            { assert snapshot(path(process.out.versions[0]).yaml, anndata(h5ad).yaml).match() }
            )
        }

    }

    test("Should write to a custom output layer") {

        when {
            params {
                outdir = "$outputDir"
            }
            process {
                """
                input[0] = channel.of([
                        [ id: 'test' ],
                        file(params.modules_testdata_base_path + 'genomics/homo_sapiens/scrnaseq/h5ad/SRR28679756_filtered_matrix.h5ad', checkIfExists: true),
                        []
                    ]
                )
                input[1] = []
                input[2] = "X"
                input[3] = "ambient_corrected_decontx"
                """
            }
        }

        then {
            def h5ad = process.out.h5ad[0][1]
            assertAll(
            { assert process.success },
            { assert snapshot(path(process.out.versions[0]).yaml, anndata(h5ad).yaml).match() },
            { assert "ambient_corrected_decontx" in anndata(h5ad).layers }
            )
        }

    }

    test("Should run without failures with raw - stub") {

        options '-stub'

        when {
            params {
                outdir = "$outputDir"
            }
            process {
                """
                input[0] = channel.of([
                        [ id: 'test' ],
                        file(params.modules_testdata_base_path + 'genomics/homo_sapiens/scrnaseq/h5ad/SRR28679756_filtered_matrix.h5ad', checkIfExists: true),
                        file(params.modules_testdata_base_path + 'genomics/homo_sapiens/scrnaseq/h5ad/SRR28679756_raw_matrix.h5ad', checkIfExists: true)
                    ]
                )
                input[1] = "sample"
                input[2] = "X"
                input[3] = "X"
                """
            }
        }

        then {
            assertAll(
            { assert process.success },
            { assert snapshot(process.out).match() }
            )
        }

    }

}
