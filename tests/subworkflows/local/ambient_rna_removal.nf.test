nextflow_workflow {

    name "Test Workflow AMBIENT_RNA_REMOVAL"
    script "subworkflows/local/ambient_rna_removal.nf"
    workflow "AMBIENT_RNA_REMOVAL"

    test("Should run with 'none' ambient removal") {

        when {
            params {
                outdir = "$outputDir"
                ambient_removal = 'none'
            }
            workflow {
                """
                input[0] = Channel.of([
                        [ id: 'test' ],
                        file(params.pipelines_testdata_base_path + 'pbmc/SRR28679759_filtered_matrix.h5ad', checkIfExists: true),
                        file(params.pipelines_testdata_base_path + 'pbmc/SRR28679759_raw_matrix.h5ad', checkIfExists: true)
                    ]
                )
                """
            }
        }

        then {
            assert workflow.success
            assert snapshot(workflow.out).match()
        }

    }

    test("Should fail with unknown ambient removal method") {

        when {
            params {
                outdir = "$outputDir"
                ambient_removal = 'test'
            }
            workflow {
                """
                input[0] = Channel.of([
                        [ id: 'test' ],
                        file(params.pipelines_testdata_base_path + 'pbmc/SRR28679759_filtered_matrix.h5ad', checkIfExists: true),
                        file(params.pipelines_testdata_base_path + 'pbmc/SRR28679759_raw_matrix.h5ad', checkIfExists: true)
                    ]
                )
                """
            }
        }

        then {
            assert !workflow.success
        }

    }

    test("Should run with 'decontx' ambient removal") {

        when {
            params {
                outdir = "$outputDir"
                ambient_removal = 'decontx'
            }
            workflow {
                """
                input[0] = Channel.of([
                        [ id: 'test', batch_col: 'sample', counts_layer: 'X' ],
                        file(params.pipelines_testdata_base_path + 'pbmc/SRR28679759_filtered_matrix.h5ad', checkIfExists: true),
                        file(params.pipelines_testdata_base_path + 'pbmc/SRR28679759_raw_matrix.h5ad', checkIfExists: true)
                    ]
                )
                """
            }
        }

        then {
            assert workflow.success
            assert snapshot(
                // Hashing does not work due to this issue:
                // https://github.com/scverse/anndataR/issues/272
                workflow.out.versions,
                file(workflow.out.h5ad.get(0).get(1)).exists(),
                file(workflow.out.h5ad.get(0).get(1)).size()
            ).match()
        }

    }

    test("Should run with 'soupx' ambient removal") {

        when {
            params {
                outdir = "$outputDir"
                ambient_removal = 'soupx'
            }
            workflow {
                """
                input[0] = Channel.of([
                        [ id: 'test', input_layer: 'X' ],
                        file(params.pipelines_testdata_base_path + 'pbmc/SRR28679759_filtered_matrix.h5ad', checkIfExists: true),
                        file(params.pipelines_testdata_base_path + 'pbmc/SRR28679759_raw_matrix.h5ad', checkIfExists: true)
                    ]
                )
                """
            }
        }

        then {
            assert workflow.success
            assert snapshot(
                // Hashing does not work due to this issue:
                // https://github.com/scverse/anndataR/issues/272
                workflow.out.versions,
                file(workflow.out.h5ad.get(0).get(1)).exists(),
                file(workflow.out.h5ad.get(0).get(1)).size()
            ).match()
        }

    }

    test("Should run with 'scar' ambient removal") {

        when {
            params {
                outdir = "$outputDir"
                ambient_removal = 'scar'
            }
            workflow {
                """
                input[0] = Channel.of([
                        [ id: 'test' ],
                        file(params.pipelines_testdata_base_path + 'pbmc/SRR28679759_filtered_matrix.h5ad', checkIfExists: true),
                        file(params.pipelines_testdata_base_path + 'pbmc/SRR28679759_raw_matrix.h5ad', checkIfExists: true)
                    ]
                )
                """
            }
        }

        then {
            assert workflow.success
            assert snapshot(workflow.out).match()
        }

    }

    test("Should run with 'cellbender' ambient removal") {

        when {
            params {
                outdir = "$outputDir"
                ambient_removal = 'cellbender'
            }
            workflow {
                """
                input[0] = Channel.of([
                        [ id: 'test' ],
                        file(params.pipelines_testdata_base_path + 'pbmc/SRR28679759_filtered_matrix.h5ad', checkIfExists: true),
                        file(params.pipelines_testdata_base_path + 'pbmc/SRR28679759_raw_matrix.h5ad', checkIfExists: true)
                    ]
                )
                """
            }
        }

        then {
            assert workflow.success
            assert snapshot(workflow.out).match()
        }

    }

}
