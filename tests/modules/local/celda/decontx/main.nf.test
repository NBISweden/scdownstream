nextflow_process {

    name "Test Process CELDA_DECONTX"
    script "modules/local/celda/decontx/main.nf"
    process "CELDA_DECONTX"

    setup {
        run("SCANPY_PCA") {
            script "modules/local/scanpy/pca/main.nf"
            process {
                """
                input[0] = Channel.of([
                        [ id: 'test' ],
                        file(params.pipelines_testdata_base_path + 'pbmc/SRR28679759_filtered_matrix.h5ad', checkIfExists: true)
                    ]
                )
                """
            }
        }
        run("SCANPY_NEIGHBORS") {
            script "modules/local/scanpy/neighbors/main.nf"
            process {
                """
                input[0] = SCANPY_PCA.out.h5ad
                """
            }
        }
        run("SCANPY_LEIDEN") {
            script "modules/local/scanpy/leiden/main.nf"
            process {
                """
                input[0] = SCANPY_NEIGHBORS.out.h5ad.map { meta, h5ad -> [meta, h5ad, 1.0] }
                input[1] = false
                """
            }
        }
    }

    test("Should run without failures without raw - single batch") {

        config "./nextflow.config"

        when {
            params {
                outdir = "$outputDir"
            }
            process {
                """
                input[0] = Channel.of([
                        [ id: 'test' ],
                        file(params.pipelines_testdata_base_path + 'pbmc/SRR28679756_filtered_matrix.h5ad', checkIfExists: true),
                        []
                    ]
                )
                input[1] = "sample"
                input[2] = "X"
                """
            }
        }

        then {
            assertAll(
            { assert process.success },
            { assert snapshot(
                // Hashing does not work due to this issue:
                // https://github.com/scverse/anndataR/issues/272
                process.out.versions,
                file(process.out.h5ad.get(0).get(1)).exists(),
                file(process.out.h5ad.get(0).get(1)).size()
            ).match() }
            )
        }

    }

    test("Should run without failures without raw - multi-batch") {

        config "./nextflow.config"

        when {
            params {
                outdir = "$outputDir"
            }
            process {
                """
                input[0] = SCANPY_LEIDEN.out.h5ad.map { meta, h5ad -> [meta, h5ad, []] }
                input[1] = "leiden"
                input[2] = "X"
                """
            }
        }

        then {
            assertAll(
            { assert process.success },
            { assert snapshot(
                process.out.versions,
                file(process.out.h5ad.get(0).get(1)).exists(),
                file(process.out.h5ad.get(0).get(1)).size()
            ).match() }
            )
        }

    }

    test("Should run without failures without raw - stub") {

        config "./nextflow.config"
        options '-stub'

        when {
            params {
                outdir = "$outputDir"
            }
            process {
                """
                input[0] = Channel.of([
                        [ id: 'test' ],
                        file(params.pipelines_testdata_base_path + 'pbmc/SRR28679756_filtered_matrix.h5ad', checkIfExists: true),
                        []
                    ]
                )
                input[1] = "sample"
                input[2] = "X"
                """
            }
        }

        then {
            assertAll(
            { assert process.success },
            { assert snapshot(process.out).match() }
            )
        }

    }

    test("Should run without failures with raw") {

        config "./nextflow.config"

        when {
            params {
                outdir = "$outputDir"
            }
            process {
                """
                input[0] = SCANPY_LEIDEN.out.h5ad.map { meta, h5ad -> [meta, h5ad, file(params.pipelines_testdata_base_path + 'pbmc/SRR28679756_raw_matrix.h5ad', checkIfExists: true)] }
                input[1] = "leiden"
                input[2] = "X"
                """
            }
        }

        then {
            assertAll(
            { assert process.success },
            { assert snapshot(
                process.out.versions,
                file(process.out.h5ad.get(0).get(1)).exists(),
                file(process.out.h5ad.get(0).get(1)).size()
            ).match() }
            )
        }

    }

    test("Should run without failures with raw - stub") {

        config "./nextflow.config"
        options '-stub'

        when {
            params {
                outdir = "$outputDir"
            }
            process {
                """
                input[0] = SCANPY_LEIDEN.out.h5ad.map { meta, h5ad -> [meta, h5ad, file(params.pipelines_testdata_base_path + 'pbmc/SRR28679756_raw_matrix.h5ad', checkIfExists: true)] }
                input[1] = "leiden"
                input[2] = "X"
                """
            }
        }

        then {
            assertAll(
            { assert process.success },
            { assert snapshot(process.out).match() }
            )
        }

    }

}
