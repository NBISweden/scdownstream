nextflow_process {

    name "Test Process ADATA_ENTROPY"
    script "modules/local/adata/entropy/main.nf"
    process "ADATA_ENTROPY"

    test("Should run without failures") {

        when {
            params {
                outdir = "$outputDir"
            }
            process {
                """
                input[0] = Channel.of([
                        [id: 'test'],
                        file(params.pipelines_testdata_base_path + 'pbmc/combined_filtered_matrix.h5ad', checkIfExists: true)
                    ]
                )
                input[1] = 'leiden'
                input[2] = 'sample'
                """
            }
        }

        then {
            assertAll(
            { assert process.success },
            { assert snapshot(process.out).match() }
            )
        }

    }

    test("Should run without failures - stub") {

        options '-stub'

        when {
            params {
                outdir = "$outputDir"
            }
            process {
                """
                input[0] = Channel.of([
                        [id: 'test'],
                        file(params.pipelines_testdata_base_path + 'pbmc/combined_filtered_matrix.h5ad', checkIfExists: true)
                    ]
                )
                input[1] = 'leiden'
                input[2] = 'sample'
                """
            }
        }

        then {
            assertAll(
            { assert process.success },
            { assert snapshot(process.out).match() }
            )
        }

    }

}
